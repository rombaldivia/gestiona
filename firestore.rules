rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function companyDoc(companyId) {
      return get(/databases/$(database)/documents/companies/$(companyId));
    }

    function companyExists(companyId) {
      return exists(/databases/$(database)/documents/companies/$(companyId));
    }

    function isOwner(companyId) {
      return signedIn() &&
        companyExists(companyId) &&
        companyDoc(companyId).data.ownerUid == request.auth.uid;
    }

    function memberExists(companyId) {
      return signedIn() &&
        exists(/databases/$(database)/documents/companies/$(companyId)/members/$(request.auth.uid));
    }

    function memberDoc(companyId) {
      return get(/databases/$(database)/documents/companies/$(companyId)/members/$(request.auth.uid));
    }

    function isMember(companyId) {
      return isOwner(companyId) || memberExists(companyId);
    }

    function companyIsPro(companyId) {
      return companyExists(companyId) &&
        (
          companyDoc(companyId).data.plan == 'pro' ||
          companyDoc(companyId).data.subscriptionPlan == 'pro'
        );
    }

    function joinCodeDoc(code) {
      return get(/databases/$(database)/documents/company_join_codes/$(code));
    }

    function hasJoinCode(code) {
      return exists(/databases/$(database)/documents/company_join_codes/$(code));
    }

    function validJoinCodeForCompany(code, companyId) {
      return hasJoinCode(code) &&
        joinCodeDoc(code).data.companyId == companyId &&
        (
          !('active' in joinCodeDoc(code).data) ||
          joinCodeDoc(code).data.active == true
        ) &&
        (
          !('expiresAt' in joinCodeDoc(code).data) ||
          joinCodeDoc(code).data.expiresAt > request.time
        );
    }

    function moduleAccess(companyId, key) {
      return memberExists(companyId)
        ? memberDoc(companyId).data.permissions[key]
        : 'none';
    }

    function canViewModule(companyId, key) {
      return isOwner(companyId) ||
        (memberExists(companyId) &&
          (
            moduleAccess(companyId, key) == 'view' ||
            moduleAccess(companyId, key) == 'edit'
          ));
    }

    function canEditModule(companyId, key) {
      return isOwner(companyId) ||
        (memberExists(companyId) && moduleAccess(companyId, key) == 'edit');
    }

    match /users/{uid} {
      allow create, update: if signedIn() && request.auth.uid == uid;
      allow read: if signedIn() && request.auth.uid == uid;
      allow delete: if false;
    }

    match /companies/{companyId} {
      allow create: if signedIn() && request.resource.data.ownerUid == request.auth.uid;

      // Cualquier miembro puede leer metadata básica de su empresa;
      // owner puede actualizar/borrar
      allow read: if signedIn() && isMember(companyId);
      allow update, delete: if signedIn() && isOwner(companyId);

      match /private/{docId} {
        allow read, write: if signedIn() && isOwner(companyId);
      }

      match /members/{uid} {
        allow read: if signedIn() && (
          isOwner(companyId) ||
          request.auth.uid == uid
        );

        // Alta por QR
        allow create: if signedIn()
          && request.auth.uid == uid
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.companyId == companyId
          && request.resource.data.companyName is string
          && request.resource.data.name is string
          && request.resource.data.email is string
          && request.resource.data.role is string
          && request.resource.data.joinedAtMs is int
          && request.resource.data.isAnonymous is bool
          && request.resource.data.joinCode is string
          && (!('permissions' in request.resource.data) || request.resource.data.permissions is map)
          && validJoinCodeForCompany(request.resource.data.joinCode, companyId)
          && companyIsPro(companyId);

        // Solo owner edita rol, nombre, email y permisos
        allow update: if signedIn() && isOwner(companyId);

        // Solo owner elimina; al borrar el doc, pierde acceso al instante
        allow delete: if signedIn() && isOwner(companyId);
      }

      match /inventory_items/{docId} {
        allow read: if signedIn() && canViewModule(companyId, 'inventory');
        allow create, update, delete: if signedIn() && canEditModule(companyId, 'inventory');
      }

      match /stock_movements/{docId} {
        allow read: if signedIn() && canViewModule(companyId, 'inventory');
        allow create, update, delete: if signedIn() && canEditModule(companyId, 'inventory');
      }

      match /work_orders/{workOrderId} {
        allow read: if signedIn() && canViewModule(companyId, 'workOrders');
        allow create, update, delete: if signedIn() && canEditModule(companyId, 'workOrders');
      }

      match /quotes/{quoteId} {
        allow read: if signedIn() && canViewModule(companyId, 'quotes');
        allow create, update, delete: if signedIn() && canEditModule(companyId, 'quotes');
      }

      match /sales/{saleId} {
        allow read: if signedIn() && canViewModule(companyId, 'sales');
        allow create, update, delete: if signedIn() && canEditModule(companyId, 'sales');
      }
    }

    match /company_join_codes/{code} {
      allow get: if signedIn();
      allow list: if false;

      allow create: if signedIn()
        && request.resource.data.companyId is string
        && isOwner(request.resource.data.companyId);

      allow update: if signedIn()
        && resource.data.companyId is string
        && request.resource.data.companyId == resource.data.companyId
        && isOwner(resource.data.companyId);

      allow delete: if signedIn()
        && resource.data.companyId is string
        && isOwner(resource.data.companyId);
    }

    match /company_members/{memberDoc} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
