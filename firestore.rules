rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function companyDoc(companyId) {
      return get(/databases/$(database)/documents/companies/$(companyId));
    }

    function companyExists(companyId) {
      return exists(/databases/$(database)/documents/companies/$(companyId));
    }

    function isOwner(companyId) {
      return signedIn() &&
        companyExists(companyId) &&
        companyDoc(companyId).data.ownerUid == request.auth.uid;
    }

    function isMemberSub(companyId) {
      return signedIn() &&
        exists(/databases/$(database)/documents/companies/$(companyId)/members/$(request.auth.uid));
    }

    function isMember(companyId) {
      return isOwner(companyId) || isMemberSub(companyId);
    }

    function joinCodeDoc(code) {
      return get(/databases/$(database)/documents/company_join_codes/$(code));
    }

    function hasJoinCode(code) {
      return exists(/databases/$(database)/documents/company_join_codes/$(code));
    }

    function validJoinCodeForCompany(code, companyId) {
      return hasJoinCode(code) &&
        joinCodeDoc(code).data.companyId == companyId &&
        (
          !('active' in joinCodeDoc(code).data) ||
          joinCodeDoc(code).data.active == true
        ) &&
        (
          !('expiresAt' in joinCodeDoc(code).data) ||
          joinCodeDoc(code).data.expiresAt > request.time
        );
    }

    match /users/{uid} {
      allow create, update: if signedIn() && request.auth.uid == uid;
      allow read: if signedIn() && request.auth.uid == uid;
      allow delete: if false;
    }

    match /companies/{companyId} {
      allow create: if signedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow read: if signedIn() && isMember(companyId);
      allow update, delete: if signedIn() && isOwner(companyId);

      match /private/{docId} {
        allow read, write: if signedIn() && isOwner(companyId);
      }

      match /members/{uid} {
        allow read: if signedIn() && (isOwner(companyId) || request.auth.uid == uid);

        allow create: if signedIn()
          && request.auth.uid == uid
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.joinCode is string
          && validJoinCodeForCompany(request.resource.data.joinCode, companyId);

        allow update: if signedIn() && (isOwner(companyId) || request.auth.uid == uid);
        allow delete: if signedIn() && isOwner(companyId);
      }

      match /inventory_items/{docId} {
        allow read, write: if signedIn() && isMember(companyId);
      }

      match /stock_movements/{docId} {
        allow read, write: if signedIn() && isMember(companyId);
      }

      match /work_orders/{workOrderId} {
        allow read, write: if signedIn() && isMember(companyId);
      }

      match /quotes/{quoteId} {
        allow read, write: if signedIn() && isMember(companyId);
      }
    }

    match /company_join_codes/{code} {
      allow get: if signedIn();
      allow list: if false;

      allow create: if signedIn()
        && request.resource.data.companyId is string
        && isOwner(request.resource.data.companyId);

      allow update: if signedIn()
        && resource.data.companyId is string
        && request.resource.data.companyId == resource.data.companyId
        && isOwner(resource.data.companyId);

      allow delete: if signedIn()
        && resource.data.companyId is string
        && isOwner(resource.data.companyId);
    }

    match /company_members/{memberDoc} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
